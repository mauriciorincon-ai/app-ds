# Plantilla de variables de entorno. Copia a .env.local (gitignored) y rellena.
# En Vercel se configuran como Environment Variables del proyecto.

# Sentry — observabilidad de errores. El DSN es PÚBLICO por diseño (viaja al
# bundle del cliente). Aun así no se hardcodea: vive en .env.local / Vercel.
# Los logs jamás incluyen contenido del dataset (solo metadatos: nº filas/columnas/tipos).
NEXT_PUBLIC_SENTRY_DSN=

# Narración IA (S2) — SOLO server-side (sin NEXT_PUBLIC_: la key jamás viaja al cliente).
# El LLM narra la explicabilidad; su salida se verifica contra los números antes de mostrarse.
# Sin proveedor/key/kill-switch la app funciona igual con plantillas deterministas.
# NARRATION_PROVIDER: groq | mock (mock = CI/tests, sin red)
NARRATION_PROVIDER=
# Kill-switch: "true" para habilitar la narración; cualquier otro valor la apaga (fallback plantilla).
NARRATION_ENABLED=
# API key del proveedor (Groq free tier — ver decisions/005). Solo .env.local / Vercel env.
GROQ_API_KEY=
